# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# image sources (compressed derivatives are committed under public/images)
/public/stripe-office.png

# canon videos used by /creative-ai-workshop video sections. The large
# HEVC source masters stay local (too big, and HEVC won't play in
# Chrome/Firefox). The compressed, web-ready H.264 cuts below are
# committed and served as static assets from /public on Vercel.
/public/videos/*.mp4
!/public/videos/anthropic-prompting-advice.mp4
!/public/videos/michael-levin-cognitive-interfaces.mp4
!/public/videos/loop-smug-owl-ai-atl.mp4

# QA, working notes, browser session captures — kept local, never committed
.cursor/plans/
.playwright-mcp/
qa-screenshots/

# Root-level captures (QA screenshots dropped at repo root by various
# scripts and browser-mcp sessions). Tracked images live under public/
# or specific feature subdirs, never at the repo root.
/*.png
/*.txt

.agents/

# video studio temp workspace (uploads, renders, compiled compositions)
.video-studio/

# typescript
*.tsbuildinfo
next-env.d.ts

.env*.local
